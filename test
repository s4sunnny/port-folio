<Data>
  <Group ID="CONTENT-SECTION" Name="Content section">
    <Datum ID="BLOCK-LAYOUT" Type="SelectSingle" Name="Block Layout">
      <Option>
        <Display>1 column</Display>
        <Value>1</Value>
      </Option>
      <Option>
        <Display>2 columns</Display>
        <Value>2</Value>
      </Option>
      <Option>
        <Display>3 columns</Display>
        <Value>3</Value>
      </Option>
      <Option>
        <Display>4 columns</Display>
        <Value>4</Value>
      </Option>
    </Datum>
    <Datum ID="BACKGROUND-COLOR" Type="SelectSingle" Name="Background color">
      <Option>
        <Display>Yes</Display>
        <Value>Yes</Value>
      </Option>
      <Option>
        <Display>No</Display>
        <Value>No</Value>
      </Option>
    </Datum>
