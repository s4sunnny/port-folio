    <Datum ID="CTALINK1" Name="Button 1 Link" Type="PageLink"/>
    <Datum ID="CTAMODAL1" Type="SelectSingle" Name="Sign in Modal 1 (Optional)">
      <Option Selected="true">
        <Display/>
        <Value/>
      </Option>
      <Option>
        <Display>Shipping</Display>
        <Value>shipping</Value>
      </Option>
    </Datum>
    <Datum ID="CTACSS1" Name="Button 1 CSS Classes" Type="String"/>
    <Datum ID="CTAID1" Name="Analytics 1 ID (Optional)" Type="String"/>
    <Datum ID="CTACUSTMODALID1" Name="Custom Modal 1 ID (Optional)" Type="String"/>
    <Datum ID="CTACUSTOMMODALBODY1" Name="CTA Custom Modal Body 1 (Optional)" Type="Textarea"/>
    <Datum ID="CTA2" Name="Button 2 Text" Type="String"/>
    <Datum ID="CTATYPE2" Type="SelectSingle" Name="Button 2 Type">
      <Option Selected="true">
        <Display>Link</Display>
        <Value>link</Value>
      </Option>
      <Option>
        <Display>Primary Button</Display>
        <Value>button</Value>
      </Option>
      <Option>
        <Display>Secondary Button</Display>
        <Value>button secondary</Value>
      </Option>
    </Datum>
    <Datum ID="CTALINK2" Name="Button 2 Link" Type="PageLink"/>
    <Datum ID="CTAMODAL2" Type="SelectSingle" Name="Sign in Modal 2 (Optional)">
      <Option Selected="true">
        <Display/>
        <Value/>
      </Option>
      <Option>
        <Display>Shipping</Display>
        <Value>shipping</Value>
      </Option>
    </Datum>
    <Datum ID="CTACSS2" Name="Button 2 CSS Classes" Type="String"/>
    <Datum ID="CTAID2" Name="Analytics 2 ID (Optional)" Type="String"/>
    <Datum ID="CTACUSTMODALID2" Name="Custom Modal 2 ID (Optional)" Type="String"/>
    <Datum ID="CTACUSTOMMODALBODY2" Name="CTA Custom Modal Body 2 (Optional)" Type="Textarea"/>
    <Datum ID="CTA3" Name="Button 3 Text" Type="String"/>
    <Datum ID="CTATYPE3" Type="SelectSingle" Name="Button 3 Type">
      <Option Selected="true">
        <Display>Link</Display>
        <Value>link</Value>
      </Option>
      <Option>
        <Display>Primary Button</Display>
        <Value>button</Value>
      </Option>
      <Option>
        <Display>Secondary Button</Display>
