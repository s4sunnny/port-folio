    <Datum ID="IMGTYPE" Type="SelectSingle" Name="Image Type">
      <Option Selected="true">
        <Display>Illustration</Display>
        <Value>illustration</Value>
      </Option>
      <Option>
        <Display>Illustration (Small)</Display>
        <Value>illustration-small</Value>
      </Option>
      <Option>
        <Display>Photography</Display>
        <Value>photography</Value>
      </Option>
      <Option>
        <Display>Icon</Display>
        <Value>icon</Value>
      </Option>
      <Option>
        <Display>Logo</Display>
        <Value>logo</Value>
      </Option>
      <Option>
        <Display>CPC Logo</Display>
        <Value>cpc-logo</Value>
      </Option>
      <Option>
        <Display>CPC Postmark</Display>
        <Value>cpc-postmark</Value>
      </Option>
      <Option>
        <Display>Custom</Display>
        <Value>custom</Value>
      </Option>
    </Datum>
    <Datum ID="VideoUrl" Name="VideoUrl" Type="String"/>
    <Datum ID="VideoTitle" Name="VideoTitle" Type="String"/>
    <Datum ID="CTA1" Name="Button 1 Text" Type="String"/>
    <Datum ID="CTATYPE1" Type="SelectSingle" Name="Button 1 Type">
