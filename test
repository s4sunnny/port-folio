    <Datum ID="section-intro" Name="Intro text" Type="Textarea"/>
    <Datum ID="intro-only" Type="SelectSingle" Name="Intro only?">
      <Option Selected="true">
        <Display>No</Display>
        <Value>No</Value>
      </Option>
      <Option>
        <Display>Yes</Display>
        <Value>Yes</Value>
      </Option>
    </Datum>
  </Group>
  <Group ID="COLUMN-GROUP" Name="Info block" Replicatable="true" CloneGroupID="INFOBLOCK-COLGROUP">
