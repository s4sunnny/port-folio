      </Option>
    </Datum>
    <Datum ID="CTALINK3" Name="Button 3 Link" Type="PageLink"/>
    <Datum ID="CTAMODAL3" Type="SelectSingle" Name="Sign in Modal 3 (Optional)">
      <Option Selected="true">
        <Display/>
        <Value/>
      </Option>
      <Option>
        <Display>Shipping</Display>
        <Value>shipping</Value>
      </Option>
